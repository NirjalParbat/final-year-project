{
  "name": "ghumfir",
  "version": "1.0.0",
  "description": "Ghumfir Tourism Management Platform - MERN Stack",
  "scripts": {
    "server": "npm --prefix server run start",
    "server:dev": "npm --prefix server run dev",
    "client": "npm --prefix client run dev",
    "dev": "concurrently \"npm run server:dev\" \"npm run client\"",
    "start": "npm run server",
    "postinstall": "npm --prefix server install",
    "seed": "node server/utils/seedAdmin.js",
    "install:all": "npm --prefix server install && npm --prefix client install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

PORT=8080
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRE=1d

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM_NAME=Ghumfir
MAIL_LOGO_URL=https://res.cloudinary.com/your_cloud/image/upload/your_logo.png

KHALTI_SECRET_KEY=your_khalti_secret_key
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:8080
SESSION_SECRET=replace_with_random_64_char_secret
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback
REDIS_URL=redis://localhost:6379

# Optional: Resend HTTPS fallback for environments where SMTP ports timeout
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=noreply@your-domain.com
